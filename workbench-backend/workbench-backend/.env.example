# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/workbench

# Used to sign JWTs — generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-64-char-hex-string

# Where the frontend is served from (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

PORT=3001
